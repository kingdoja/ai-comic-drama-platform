# LLM 配置
# 选择 LLM 提供商: qwen, openai, claude
LLM_PROVIDER=qwen

# 可选：指定模型名称（留空使用默认模型）
# LLM_MODEL=qwen-plus

# ===== 通义千问配置 =====
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here
# 或使用 DashScope API Key
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 可选模型:
# - qwen-turbo (快速，便宜)
# - qwen-plus (平衡，推荐)
# - qwen-max (最强，贵)

# ===== OpenAI 配置 =====
# 获取 API Key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# 可选模型:
# - gpt-4o-mini (快速，便宜)
# - gpt-4o (最新，推荐)
# - gpt-4-turbo (强大)

# ===== Anthropic Claude 配置 =====
# 获取 API Key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选模型:
# - claude-3-5-sonnet-20241022 (最新，推荐)
# - claude-3-opus-20240229 (最强)
# - claude-3-haiku-20240307 (快速)
